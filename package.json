{
  "name": "cli-memory",
  "version": "1.0.0",
  "description": "Config & session memory for Claude Code, Codex & Gemini CLI",
  "type": "module",
  "scripts": {
    "dev": "pnpm tauri dev",
    "build": "pnpm tauri build",
    "tauri": "tauri",
    "dev:renderer": "vite",
    "dev:web": "vite --mode web",
    "dev:server": "cargo run --manifest-path crates/server/Cargo.toml",
    "build:renderer": "vite build",
    "build:web": "vite build --mode web",
    "start:web": "./start-web.sh",
    "stop:web": "./stop-web.sh",
    "smoke:web-local": "node scripts/web-release-smoke.mjs --url http://127.0.0.1:17666",
    "smoke:web-release": "node scripts/web-release-smoke.mjs",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,css,json}\"",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest watch",
    "release:sync-version": "node scripts/release-manager.mjs sync",
    "release:cut": "node scripts/release-manager.mjs release"
  },
  "keywords": [],
  "author": "Jason Young",
  "license": "MIT",
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "code-inspector-plugin": "^1.3.3",
    "cross-fetch": "^4.1.0",
    "jsdom": "^29.1.0",
    "msw": "^2.13.6",
    "postcss": "^8.5.12",
    "playwright": "^1.54.2",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
